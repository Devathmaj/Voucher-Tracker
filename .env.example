# IS_PROD=false → create tables + seed sources/keywords on startup
# IS_PROD=true  → skip schema/seed (expects migrations already applied; DML-only DB role)
IS_PROD=false
LOG_LEVEL=INFO
# Local: postgresql+asyncpg://postgres:postgres@localhost:5432/voucherbot
# Supabase (session pooler, IPv4): postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/voucherbot"

# Scraping policy (see deep-research-report)
# Identifying User-Agent; leave empty to auto-build from contact email.
# SCRAPER_USER_AGENT=VoucherBot/0.1 (+https://example.com; contact=you@example.com)
SCRAPER_CONTACT_EMAIL=your_email_id
SCRAPER_RESPECT_ROBOTS=true
SCRAPER_MIN_DELAY_SECONDS=2.0

# Reddit Ingestion
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USER_AGENT=VoucherBot/0.1.0
REDDIT_INGESTION_ENABLED=false

# Email Automation
RESEND_API_KEY="your_resend_api_key"
EMAIL_ID="your_email_id"
EMAIL_MIN_INTERVAL_SECONDS=5.0

# AI Module
GEMINI_API_KEY="your_gemini_api_key"
GROQ_API_KEY="your_groq_api_key"
